#### GLOBAL ####
## docker networks:
DOCKER_NETWORKS_SUBNET_PREFIX="192.168"
# nodes:
DOCKER_NODE_NETWORK_NAME="ebsi-${NODE_NAME}"
DOCKER_NODE_NETWORK_SUBNET="${DOCKER_NETWORKS_SUBNET_PREFIX}.${DOCKER_NODE_NETWORK_SUBNET_ID}.0/24"  # e.g.: 192.168.<node_subnet>.0/24
DOCKER_NODE_NETWORK_GW="${DOCKER_NETWORKS_SUBNET_PREFIX}.${DOCKER_NODE_NETWORK_SUBNET_ID}.1"
DOCKER_NODE_EXPOSE_PORTS_IP=${DOCKER_NODE_NETWORK_GW}
DOCKER_NODE_NETWORK_IP_RANGE="${DOCKER_NETWORKS_SUBNET_PREFIX}.${DOCKER_NODE_NETWORK_SUBNET_ID}.128/25"
NODE_REVERSE_PROXY_LOCAL_IP="${DOCKER_NETWORKS_SUBNET_PREFIX}.${DOCKER_NODE_NETWORK_SUBNET_ID}.10"
# besu network (shared across all nodes and infra monitoring):
BESU_LOCAL_IP="${DOCKER_NETWORKS_SUBNET_PREFIX}.${DOCKER_NODE_NETWORK_SUBNET_ID}.5"    # besu IP in each node network (e.g. 192.168.55.5 for besu inside the node1 network)
BESU_LOCAL_IP2="${DOCKER_NETWORKS_SUBNET_PREFIX}.50.${DOCKER_NODE_NETWORK_SUBNET_ID}"  # besu IPs on the shared besu network (e.g. 192.168.50.55 for besu in node1)
BESU_P2P_HOST="${BESU_LOCAL_IP2}" # the IP besu advertises to the other nodes
BESU_BOOTNODE_HOST="${DOCKER_NETWORKS_SUBNET_PREFIX}.50.55"  # use node1 as the bootnode
# infra monitoring:
DOCKER_INFRA_NETWORK_NAME="ebsi-infra"
DOCKER_INFRA_NETWORK_SUBNET="${DOCKER_NETWORKS_SUBNET_PREFIX}.${DOCKER_NODE_NETWORK_SUBNET_ID}.0/24"  # e.g.: 192.168.<node_subnet>.0/24
DOCKER_INFRA_NETWORK_GW="${DOCKER_NETWORKS_SUBNET_PREFIX}.${DOCKER_NODE_NETWORK_SUBNET_ID}.1"
DOCKER_INFRA_EXPOSE_PORTS_IP=${DOCKER_INFRA_NETWORK_GW}
DOCKER_INFRA_NETWORK_IP_RANGE="${DOCKER_NETWORKS_SUBNET_PREFIX}.${DOCKER_NODE_NETWORK_SUBNET_ID}.128/25"

# directories for container volumes, env files and git source repos:
# NOTE: when git repos are public, use "https://...#branch:subdir"
ENV_DIR_CORE_SERVICES="../../env"                   # relative to /base/core-services
GIT_CORE_SERVICES="../../sources/core-services"     # relative to /base/core-services
GIT_BESU="../sources/besu-plugins"                  # relative to /base
GIT_HEALTHCHECK="../sources/healthcheck"            # relative to /base
ENV_DIR="../env"                                    # relative to /base
VOLUMES_ROOTDIR="../volumes/${NODE_NAME}"           # relative to /base

# environment (just reported in monitoring dashboards, no technical function otherwise):
NODE_ENV="test"

# domain names (nodes):
TLD="test"
API_DOMAIN="ebsi.oari.io"
APP_DOMAIN="app.${NODE_NAME}.${TLD}"
BESU_DOMAIN="besu.oari.io"
BLOCKSCOUT_DOMAIN="blockscout.oari.io"
NODE_REVERSE_PROXY_DOMAIN="proxy.${NODE_NAME}.${TLD}"
# domain names (infra monitoring):
INFRA_PROMETHEUS_DOMAIN="metrics.monitoring.${TLD}"
INFRA_DASHBOARD_DOMAIN="dashboard.monitoring.${TLD}"
INFRA_PUSHPROX_DOMAIN="pushprox.monitoring.${TLD}"
NODE_PUSHPROX_URL="http://pushprox:8080"


# besu blockchain configuration:
BESU_GENESIS_FILE="../keys/genesis.json"
BESU_NODE_KEY="../keys/${NODE_NAME}/key"
BESU_BOOTNAME_PORT="48733"
BESU_BOOTNODES="enode://${BESU_BOOTNODE_PUBKEY}@${BESU_BOOTNODE_HOST}:${BESU_BOOTNAME_PORT}"
BESU_LOGGING=INFO
#BESU_OPTS: "-Xmx8g"

#### blockscout blockchain explorer (runs on node1 only) ####
BLOCKSCOUT_CHAIN_ID=6175
BLOCKSCOUT_DB_USERNAME=blockscout
BLOCKSCOUT_DB_PW=blockscout
BLOCKSCOUT_STATS_DB_USERNAME=stats
BLOCKSCOUT_STATS_DB_PW=stats
