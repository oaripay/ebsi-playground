#### CONTAINER IMAGES VERSIONS (3rd party) ###

## traefik-reverse-proxy (traefik-reverse-proxy)
IMAGE_NAME_node_reverse_proxy="traefik"
IMAGE_TAG_node_reverse_proxy="latest"

## blockscout
# blockscout-backend: tags: https://hub.docker.com/r/blockscout/blockscout/tags | source: https://github.com/blockscout/blockscout
IMAGE_TAG_blockscout_backend="latest"
# blockscout-frontend: https://github.com/blockscout/frontend
IMAGE_TAG_blockscout_frontend="latest"
# blockscout-visualizer: https://github.com/blockscout/blockscout-rs/pkgs/container/visualizer
IMAGE_TAG_blockscout_visualizer="latest"
# blockscout-sig-provider: https://github.com/blockscout/blockscout-rs/pkgs/container/sig-provider
IMAGE_TAG_blockscout_sig_provider="latest"
# blockscout-stats: https://github.com/blockscout/blockscout-rs/pkgs/container/stats
IMAGE_TAG_blockscout_stats="latest"
# blockscout-proxy (nginx):
IMAGE_NAME_blockscout_proxy="nginx"
IMAGE_TAG_blockscout_proxy="1.21.3"

## prometheus
IMAGE_NAME_prometheus="prom/prometheus"
IMAGE_TAG_prometheus="v2.55.0"

## grafana
IMAGE_NAME_grafana="grafana/grafana"
IMAGE_TAG_grafana="11.3.0"

## pushprox
IMAGE_NAME_pushprox="prometheuscommunity/pushprox"
IMAGE_TAG_pushprox="master"

